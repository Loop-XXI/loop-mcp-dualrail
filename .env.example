# ---- x402 (EVM/USDC) rail ----
# Wallet that RECEIVES payments (server) / address used by client
PAYMENT_WALLET_ADDRESS=0xYourReceivingAddress
# Client-side spending wallet (testnet only). Generate with: pnpm generate-wallet
SENDER_PRIVATE_KEY=0xYourClientPrivateKey
# Network: baseSepolia (test) or base (mainnet)
NETWORK=baseSepolia
# Optional custom x402 facilitator
# FACILITATOR_URL=https://facilitator.x402.org

# ---- L402 (Lightning) rail  [LOOP ADDITION] ----
# phoenixd hot node (Loop XXI runs this on Railway)
PHOENIXD_URL=http://127.0.0.1:9740
PHOENIXD_PASSWORD=your-phoenixd-http-password
# HMAC secret used to mint/verify L402 macaroons
L402_SECRET=change-me-to-a-long-random-string
# Spot BTC/USD used to quote sats (Loop's gateway sources this live)
BTC_USD_PRICE=65000

MCP_SERVER_URL=http://localhost:3022/mcp
PORT=3022
