{
  "name": "@loop-xxi/loop-mcp",
  "version": "0.1.0",
  "description": "Dual-rail (x402/USDC + Lightning/L402) payment transport for the Model Context Protocol. Charge agents per tool call over either rail, settled into one canonical rail-tagged ledger.",
  "license": "MIT",
  "author": "Loop XXI LLC",
  "homepage": "https://loopxxi.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/Loop-XXI/loop-mcp-dualrail"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "x402",
    "l402",
    "lightning",
    "bitcoin",
    "usdc",
    "agent-payments",
    "micropayments",
    "dual-rail"
  ],
  "main": "dist/index.js",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "bin": {
    "loop-mcp": "./dist/scripts/client-proxy.js",
    "client-proxy": "./dist/scripts/client-proxy.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch example/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "tsx example/server.ts",
    "example:run": "tsx example/client.ts",
    "proxy": "tsx src/scripts/client-proxy.ts",
    "generate-wallet": "tsx src/scripts/generateWallet.ts",
    "demo:core": "node scripts/demo-core.mjs",
    "test": "vitest run",
    "lint": "biome check ."
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1.17.0"
  },
  "dependencies": {
    "viem": "^2.33.2",
    "x402": "^0.6.5",
    "x402-fetch": "^0.6.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.17.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^22.10.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4",
    "zod": "^3.25.64"
  }
}
